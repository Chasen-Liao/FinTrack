# Polygon.io API key (free tier available)
# Sign up at: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# Anthropic-format API key (Anthropic official or compatible providers)
# Anthropic official: https://console.anthropic.com/
# MiniMax Anthropic-compatible endpoint is also supported.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SiliconFlow API key (recommended for domestic use)
# Sign up at: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# OpenAI-compatible custom LLM endpoint.
# LLM_API_KEY takes priority over SILICONFLOW_API_KEY when set.
LLM_API_KEY=
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-R1

# LLM provider: "siliconflow" (default), "custom", or "anthropic"
# For MiniMax Anthropic-compatible mode:
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.minimaxi.com/anthropic
# LLM_MODEL=MiniMax-M2.5
LLM_PROVIDER=siliconflow

# Optional Layer 1 batch-analysis override.
# Use this when batch sentiment analysis should use a different provider
# from deep analysis and range Q&A.
LAYER1_LLM_PROVIDER=
LAYER1_LLM_BASE_URL=
LAYER1_LLM_MODEL=
LAYER1_LLM_API_KEY=
